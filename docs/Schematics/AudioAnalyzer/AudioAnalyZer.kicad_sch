	(text "Teensy controller"
		(exclude_from_sim no)
		(at 149.352 21.082 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "0a0067da-1b30-4729-9f72-17e73766c32c")
	)
	(text "Teensy 4.1 controller\n\nThe Teensy handles:\n- USB communication with PC\n- ADC I2S data capture\n- DAC I2S calibration signal generation\n- Relay and range control\n- Temperature monitoring\n- Dummy load control\n- Data streaming to PC"
		(exclude_from_sim no)
		(at 218.948 65.532 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left)
		)
		(uuid "0e391d80-ce99-40b5-b35c-d18ac4f05140")
	)
	(text "Teensy 4.1 is powered from board +5 V through VIN.\nUSB is used for PC communication.\nOn an unmodified Teensy 4.1, VUSB and VIN are connected.\nIf USB and board +5 V are connected at the same time,\nthe VUSB/VIN pad connection on the Teensy must be cut."
		(exclude_from_sim no)
		(at 183.388 26.162 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left)
		)
		(uuid "3888d06d-fd06-4ca1-99d7-0e693eb8523c")
	)
	(text "Sheet hierarchy\n\nThis page provides the top-level overview \nof the audio analyzer.\nSubsystem sheets contain the detailed \nanalog, digital, calibration and \npower circuits.\nGlobal/hierarchical labels are used \nto connect signals between sheets."
		(exclude_from_sim no)
		(at 58.42 130.302 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left)
		)
		(uuid "484c791d-2b0d-41d1-9fae-92039663cb5e")
	)
	(text "Connector for dummy load control \nand temperature feedback.\n\nTemp_meas inputs must be limited to 0-3.3 V.\nStatus inputs must use valid 3.3 V logic levels.\nPull-up/pull-down states should be defined on \nthe dummy load board."
		(exclude_from_sim no)
		(at 25.908 84.328 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left)
		)
		(uuid "7e0ac445-cdf0-4280-b0db-30df684d748a")
	)
	(text "Dummy load connector"
		(exclude_from_sim no)
		(at 48.768 36.83 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "830f1d3f-aca4-4db4-9b1a-ca1de8e0b717")
	)
