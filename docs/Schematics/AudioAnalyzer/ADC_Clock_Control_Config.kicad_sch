		(uuid "6720c186-e9af-40a4-99ef-c9d9e8ae9fc8")
	)
	(text "12.288 MHz oscillator used as PCM4222 MCKI/SCKI source.\nR48 provides series damping close to the oscillator output.\nC64 is DNP and reserved for optional clock loading/filtering."
		(exclude_from_sim no)
		(at 17.78 68.58 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left)
		)
		(uuid "77cc55f1-d2f1-432f-be26-4b8d5a330961")
	)
	(text "ADC hardware configuration straps"
		(exclude_from_sim no)
		(at 54.102 89.154 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "7c3a0b03-d362-41db-ad74-3d307b2cafb7")
	)
	(text "High-pass filter control\n"
		(exclude_from_sim no)
		(at 173.228 20.574 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "99145b50-08f2-426f-801e-504aa3062881")
	)
	(text "HPFDL and HPFDR are tied together and \ncontrolled by ADC_HPF_DISABLE.\nDefault state is LOW through R67.\nDriving ADC_HPF_DISABLE HIGH disables \nthe ADC high-pass filter for DC calibration.\nR66 provides series isolation from the \nMCU/control signal."
		(exclude_from_sim no)
		(at 207.518 33.782 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left)
		)
		(uuid "ed164e43-3f51-4597-8cb0-6dfed01b3b90")
	)
