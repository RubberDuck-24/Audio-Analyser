	(text "All configuration pins are fixed by 10 kΩ resistors.\nNo configuration pin is left floating.\n\nPulled HIGH:\nFMT0, PCMEN, FS1\n\nPulled LOW:\nFS0, DSDEN, MODEN, DSDMODE, SUB0, SUB1,\nFMT1, OWL0, OWL1, S/M, DF\n\nPurpose:\n- PCM output enabled\n- DSD/modulator output disabled\n- Hardware-defined ADC mode at startup\n- Fixed serial output format and sample-rate mode"
		(exclude_from_sim no)
		(at 151.638 123.952 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left)
		)
		(uuid "46efeede-84ee-4983-832b-af1c31443dbd")
	)
